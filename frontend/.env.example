# Backend API URL for the frontend
# Local development
VITE_API_URL=http://localhost:8000/api

# For production, point this to your deployed backend API base
# VITE_API_URL=https://api.yourdomain.com/api

# Optional app basename when hosting under a subpath
# Use / for root hosting, or repository name for GitHub Pages.
# Example: VITE_APP_BASENAME=UNIMART -> https://<user>.github.io/UNIMART/
VITE_APP_BASENAME=/
